{
  "name": "studs",
  "version": "0.1.1",
  "scripts": {
    "dev": "vite",
    "dev:start": "tsx scripts/dev.ts",
    "stop": "tsx scripts/stop.ts",
    "deploy:local": "tsx scripts/deploy.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "coverage:report": "npm run test:coverage && node scripts/open-report.ts",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --max-warnings 0 --cache --cache-strategy content",
    "lint": "run-s lint:*",
    "lint:check:oxlint": "oxlint .",
    "lint:check:eslint": "eslint . --max-warnings 0 --cache --cache-strategy content",
    "lint:check": "run-s lint:check:*",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/ --log-level warn",
    "typecheck": "vue-tsc --noEmit -p tsconfig.typecheck.json",
    "validate": "npm run lint:check && npm run format:check && npm run test:run && npm run typecheck",
    "diff": "git diff --cached",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
      "oxlint --fix",
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "Robert Garrison",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@midden/stamp": "^0.2.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/uuid": "^10.0.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/math": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@lucide/vue": "^1.11.0",
    "@midden/eslint-config": "^0.3.2",
    "@midden/eslint-config-vue": "^0.2.4",
    "@midden/oxlint-config": "^0.1.1",
    "@midden/prettier-config": "^0.1.3",
    "@midden/tsconfig": "^0.1.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vitest/ui": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "~10.8.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
